<%- include('partials/header') %>

<div class="wiki-wrapper">
    <div class="centered-box">
        <h2 style="margin-bottom: 30px; margin-top: -20px;">로그인</h2>
        
        <form action="/login" method="POST">
            <div class="form-group" style="text-align: left;">
                
                <input type="text" name="username" placeholder="아이디를 입력하세요" required>
            </div>
            
            <div class="form-group" style="text-align: left; margin-top: 15px;">
                
                <input type="password" name="password" placeholder="비밀번호를 입력하세요" required>
            </div>
            
            <button type="submit" class="btn-new-doc" style="width: 100%; border: none; cursor: pointer; margin-top: 30px; padding: 15px;">
                로그인
            </button>
        </form>

        <p style="margin-top: 20px; font-size: 0.9rem; color: #777;">
            아직 계정이 없으신가요? <a href="/register" style="color: #6e8efb; text-decoration: none;">회원가입</a>
        </p>
    </div>
</div>

<%- include('partials/footer') %>