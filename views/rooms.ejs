<%- include('partials/header') %>

<div class="container" style="max-width: 650px; margin: 40px auto; text-align: center;">
    <h2 style="margin-bottom: 30px; font-weight: 700; color: #2d3436;">나의 프라이빗 룸</h2>

    <section class="room-section" style="background: #ffffff; padding: 25px; border-radius: 20px; box-shadow: 0 8px 20px rgba(0,0,0,0.06); margin-bottom: 40px; border: 1px solid #f0f0f0;">
        <h3 style="margin-top: 0; color: #636e72; font-size: 1.1rem;">참여 중인 룸</h3>
        
        <% if (rooms && rooms.length > 0) { %>
            <ul style="list-style: none; padding: 0; margin-top: 20px;">
                <% rooms.forEach(room => { %>
                    <li style="padding: 15px; border-bottom: 1px solid #f9f9f9; display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-weight: 600; font-size: 1.1rem;"><%= room.name %></span>
                        <a href="/room/<%= room._id %>" class="btn-new-doc" style="background: #00b894; padding: 5px 15px; font-size: 0.85rem;">입장하기</a>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <div class="empty-state" style="padding: 30px 0;">
                <div style="font-size: 50px; margin-bottom: 15px;">🏠</div>
                <p style="color: #b2bec3; line-height: 1.6;">참여 중인 룸이 없어요.<br>새로운 룸을 만들거나 초대 코드로 입장해보세요!</p>
            </div>
        <% } %>
    </section>

    <div style="display: flex; gap: 20px;">
        <section style="flex: 1; padding: 20px; background: #fdfdfd; border-radius: 15px; border: 1px solid #eee;">
            <h4 style="margin-top: 0;">룸 생성하기</h4>
            <form action="/room/create" method="POST">
                <input type="text" name="name" placeholder="룸 이름 입력" required style="width: 80%; padding: 10px; margin-bottom: 10px; border-radius: 20px; border: 1px solid #ddd;">
                <button type="submit" class="btn-new-doc" style="width: 90%; background: #6c5ce7;">생성</button>
            </form>
        </section>

        <section style="flex: 1; padding: 20px; background: #fdfdfd; border-radius: 15px; border: 1px solid #eee;">
            <h4 style="margin-top: 0;">코드 입장</h4>
            <form action="/room/join" method="POST">
                <input type="text" name="inviteCode" placeholder="초대 코드 입력" required style="width: 80%; padding: 10px; margin-bottom: 10px; border-radius: 20px; border: 1px solid #ddd;">
                <button type="submit" class="btn-new-doc" style="width: 90%; background: #74b9ff;">입장</button>
            </form>
        </section>
    </div>
</div>

<%- include('partials/footer') %>